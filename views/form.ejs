<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Supermarket Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background-color: #f8f9fa; }
    .navbar { background: linear-gradient(135deg , #0051ff, #00eeff); }
    .form-card { border: none; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.10); }
    .form-card .card-header { background: linear-gradient(135deg , #0051ff, #00eeff); border-radius: 16px 16px 0 0; }
    #imagePreview { width: 100%; height: 220px; object-fit: cover; border-radius: 10px; border: 2px dashed #dee2e6; }
    .preview-placeholder {
      width: 100%; height: 220px; border-radius: 10px; border: 2px dashed #dee2e6;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      color: #adb5bd; background: #f8f9fa; cursor: pointer;
    }
    .preview-placeholder i { font-size: 3rem; }
    .form-label { font-weight: 600; color: #495057; }
    .required-star { color: #dc3545; }
  </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-dark px-4 py-3 shadow">
  <span class="navbar-brand fw-bold fs-4">
    <i class="bi bi-shop me-2"></i>Supermarket Admin
  </span>
  <a href="/" class="btn btn-outline-light btn-sm">
    <i class="bi bi-arrow-left me-1"></i>กลับหน้าหลัก
  </a>
</nav>

<div class="container py-5" style="max-width:640px">
  <div class="card form-card">
    <div class="card-header py-3">
      <h5 class="mb-0 text-white fw-bold">
        <i class="bi bi-<%= product ? 'pencil-square' : 'plus-circle' %> me-2"></i><%= title %>
      </h5>
    </div>
    <div class="card-body p-4">

      <form action="<%= action %>" method="<%= method %>" enctype="multipart/form-data">

        <div class="row g-3">
          <!-- Product Name -->
          <div class="col-12">
            <label class="form-label">ชื่อสินค้า <span class="required-star">*</span></label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-tag"></i></span>
              <input type="text" name="name" class="form-control" placeholder="เช่น นมสด โฮมแบรนด์" required
                value="<%= product ? product.name : '' %>">
            </div>
          </div>

          <!-- Category -->
          <div class="col-12">
            <label class="form-label">หมวดหมู่</label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-grid"></i></span>
              <input type="text" name="category" class="form-control" placeholder="เช่น เครื่องดื่ม, ขนม, ผักผลไม้"
                value="<%= product ? product.category : '' %>">
            </div>
          </div>

          <!-- Price & Stock -->
          <div class="col-6">
            <label class="form-label">ราคา (บาท) <span class="required-star">*</span></label>
            <div class="input-group">
              <span class="input-group-text">฿</span>
              <input type="number" name="price" class="form-control" placeholder="0.00"
                min="0" step="0.01" required value="<%= product ? product.price : '' %>">
            </div>
          </div>

          <div class="col-6">
            <label class="form-label">จำนวนสต็อก <span class="required-star">*</span></label>
            <div class="input-group">
              <span class="input-group-text"><i class="bi bi-boxes"></i></span>
              <input type="number" name="stock" class="form-control" placeholder="0"
                min="0" required value="<%= product ? product.stock : '' %>">
            </div>
          </div>

          <!-- Image Upload -->
          <div class="col-12">
            <label class="form-label">รูปภาพสินค้า</label>

            <!-- Image Preview -->
            <div class="mb-2" id="previewContainer" onclick="document.getElementById('imageInput').click()" style="cursor:pointer">
              <% if (product && product.image) { %>
                <img id="imagePreview" src="/uploads/<%= product.image %>" alt="Product Image">
              <% } else { %>
                <div class="preview-placeholder" id="placeholderDiv">
                  <i class="bi bi-cloud-upload"></i>
                  <span class="mt-2 small">คลิกเพื่อเลือกรูปภาพ</span>
                </div>
                <img id="imagePreview" src="" alt="" style="display:none; width:100%; height:220px; object-fit:cover; border-radius:10px; border:2px dashed #dee2e6;">
              <% } %>
            </div>

            <input type="file" name="image" id="imageInput" class="form-control" accept="image/*"
              onchange="previewImage(this)" style="<%= (product && product.image) ? '' : '' %>">
            <div class="form-text">รองรับ JPG, PNG, GIF, WEBP | ขนาดไม่เกิน 5MB</div>
          </div>
        </div>

        <!-- Buttons -->
        <div class="d-flex gap-3 mt-4">
          <button style="background-color: #00eeff;ท" type="submit" class="btn flex-grow-1 py-2 fw-semibold">
            <i class="bi bi-check-circle me-2"></i>
            <%= product ? 'บันทึกการแก้ไข' : 'เพิ่มสินค้า' %>
          </button>
          <a href="/" class="btn btn-secondary px-4 py-2 fw-semibold">
            <i class="bi bi-x-circle me-1"></i>ยกเลิก
          </a>
        </div>

      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function previewImage(input) {
    const preview = document.getElementById('imagePreview');
    const placeholder = document.getElementById('placeholderDiv');
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        preview.src = e.target.result;
        preview.style.display = 'block';
        if (placeholder) placeholder.style.display = 'none';
      };
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>
</body>
</html>
